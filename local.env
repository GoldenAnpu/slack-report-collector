# ---------------------------------------------------------------------------
# slack-report-collector — project config
# Sensitive data (tokens) stays in ~/slack.env, not here.
# ---------------------------------------------------------------------------

# --- Single-workspace mode --------------------------------------------------

# SLACK_CHANNEL_ID=""
# SLACK_USERNAME=""
# REPORT_TYPE="slack"          # json | txt | slack

# DATE_FROM="2026-03-01"    # default: first day of current month
# DATE_TO="2026-03-31"      # default: last day of current month

# --- Multi-workspace mode (optional) ----------------------------------------
# Uncomment and fill to run multiple workspaces in parallel.
# Tokens for each workspace go into ~/slack.env as WS_SLACK_API_TOKEN.

WORKSPACES="ws1,ws2"

WS1_SLACK_CHANNEL_ID=""
WS1_SLACK_USERNAME=""
WS1_REPORT_TYPE="slack"
WS1_DATE_FROM="2026-03-01"
WS1_DATE_TO="2026-03-31"

WS2_SLACK_CHANNEL_ID=""
WS2_SLACK_USERNAME=""
WS2_REPORT_TYPE="slack"
WS2_DATE_FROM="2026-01-01"
WS2_DATE_TO="2026-01-30"
