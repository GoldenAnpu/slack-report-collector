# ---------------------------------------------------------------------------
# slack-report-collector — project config
# Sensitive data (tokens) stays in ~/slack.env, not here.
# ---------------------------------------------------------------------------

# --- Single-workspace mode --------------------------------------------------

# SLACK_CHANNEL_ID=""
# SLACK_USERNAME=""
# REPORT_TYPE="slack"          # json | txt | slack

# DATE_FROM="2026-03-01"    # default: first day of current month
# DATE_TO="2026-03-31"      # default: last day of current month

# --- Multi-workspace mode (optional) ----------------------------------------
# Uncomment and fill to run multiple workspaces in parallel.
# Tokens for each workspace go into ~/slack.env as WS_SLACK_API_TOKEN.

WORKSPACES="ws1,ws2"

WS1_SLACK_CHANNEL_ID="C05N6A37GCX"
WS1_SLACK_USERNAME="almazgimaev"
WS1_REPORT_TYPE="slack"
# WS1_DATE_FROM="2026-03-01"  # ⬅︎ uncomment to override current month by your own dates
# WS1_DATE_TO="2026-03-31"  # ⬅︎ uncomment to override current month by your own dates

WS2_SLACK_CHANNEL_ID="C09L9SSLS90"
WS2_SLACK_USERNAME="almazgimaev"
WS2_REPORT_TYPE="slack"
# WS2_DATE_FROM="2026-01-01"  # ⬅︎ uncomment to override current month by your own dates
# WS2_DATE_TO="2026-01-30"  # ⬅︎ uncomment to override current month by your own dates
